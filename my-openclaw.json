{
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://localhost:8000/v1",
        "api": "openai-completions",
        "models": [
          {
            "id": "llama3.3",
            "name": "Llama 3.3",
            "contextWindow": 128000
          }
        ]
      },
      "litellm": {
        "baseUrl": "https://litellm.hseri.com",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "Agentic",
            "name": "Agentic",
            "contextWindow": 256000,
            "maxTokens": 128000
          },
          {
            "id": "Imaging",
            "name": "Imaging",
            "contextWindow": 128000,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "litellm/Agentic"
      },
      "imageModel": {
        "primary": "litellm/Imaging"
      },
      "models": {
        "litellm/Agentic": {
          "alias": "agentic",
          "params": {
            "temperature": 0.7
          }
        },
        "litellm/Imaging": {
          "alias": "imaging",
          "params": {
            "temperature": 0.3
          }
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "gateway": {
    "trustedProxies": [
      "127.0.0.1/32"
    ],
    "controlUi": {
      "allowedOrigins": [
        "*"
      ]
    },
    "nodes": {
      "browser": {
        "mode": "off"
      }
    }
  },
  "tools": {
    "profile": "full",
    "exec": {
      "security": "full",
      "ask": "off"
    },
    "sessions": {
      "visibility": "all"
    },
    "media": {
      "image": {
        "enabled": true,
        "maxBytes": 10485760,
        "maxChars": 500,
        "models": [
          {
            "provider": "litellm",
            "model": "Imaging",
            "capabilities": [
              "image"
            ]
          }
        ]
      }
    },
    "web": {
      "search": {
        "provider": "searxng"
      }
    }
  }
}
